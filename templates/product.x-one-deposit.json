    "x_one_evolution_DaG7Gc": {
      "type": "x-one-evolution",
      "name": "X one evolution",
      "settings": {
        "nav_id": "evolution",
        "title": "The Evolution of Procolored: Redefining the World of UV &amp; Laser",
        "subtitle": "Evolution is about rewriting the rules. Procolored began in 2018 with a deep dive into UV precision. Today, we’ve mastered the synergy of UV and Laser, turning cross-process integration into systemic innovation. Every step we take is a leap toward creative production without boundaries.",
        "content_1": "Setting the standard for high-fidelity desktop production. By perfecting dual-head UV integration, we made professional material printing accessible and reliable.",
        "content_2": "Bridging the gap between printing and lamination. This hybrid solution mastered UV-DTF technology, unlocking the power to decorate curved surfaces in one seamless workflow.",
        "content_3": "The ultimate realization of systemic innovation. By unifying UV, Laser, and UV-DTF into one intelligent ecosystem, we have redefined the next-gen industrial powerhouse.",
        "image": "shopify://shop_images/The_Evolution_of_Procolored.jpg",
        "mobile_image": "shopify://shop_images/The_Evolution_of_Procolored_mb_5eb2dcfd-7508-411d-a5f4-8b43be8e19e1.jpg",
