    "showroom_faq_6pAm6q": {
      "type": "showroom-faq",
      "blocks": {
        "item_DRAiP6": {
          "type": "item",
          "settings": {
            "question": "How long does a showroom tour take?",
            "reply": "<p>The showroom tour time is typically 1-2 hours. </p>"
          }
        },
        "item_tLCNJq": {
          "type": "item",
          "settings": {
            "question": "Do I need to make an appointment in advance?",
            "reply": "<p>While walk-ins are welcome, we highly recommend booking your personalized tour in advance to ensure the best possible experience. This allows us to tailor the visit to your needs and provide dedicated time with our experts.</p>"
          }
        },
        "item_TEDFWT": {
          "type": "item",
          "settings": {
            "question": "Can I schedule a group tour?",
            "reply": "<p>Yes, we offer group tours for businesses, schools, or any organization interested in exploring our showroom. Please contact us in advance to arrange a customized group experience that suits your needs.</p>"
          }
        },
        "item_CiX7Fx": {
          "type": "item",
          "settings": {
            "question": "Is there a fee for visiting the showroom?",
            "reply": "<p>No, visiting our showroom is completely free. We want you to have the opportunity to explore our products, ask questions, and experience our technology firsthand without any obligation.</p>"
          }
        },
        "item_ipfTh8": {
          "type": "item",
          "settings": {
            "question": "Can I purchase the products on display in the showroom?",
            "reply": "<p>Yes, many of the products displayed in our showroom are available for purchase. Our staff can assist you in selecting the right products and help you with the ordering process.</p>"
          }
        },
        "item_P3WqWW": {
          "type": "item",
          "settings": {
            "question": "How can I reschedule or cancel my booking?",
            "reply": "<p>You can reschedule or cancel your booking directly from the order details page. </p><p>Please note: Changes are not allowed within 24 hours of the scheduled service time.</p>"
          }
        }
      },
