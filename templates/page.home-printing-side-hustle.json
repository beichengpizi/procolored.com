ion: relative;\n        display: inline-block;\n        margin-bottom: 30px;\n    }\n\n    .community-section-wrapper .highlight-heading {\n        color: #220509;\n        font-size: 36px;\n        font-weight: 800;\n        line-height: 1.38;\n        position: relative;\n        z-index: 1;\n    }\n\n    /* 底部粉色色块 */\n    .community-section-wrapper .highlight-heading::after {\n        content: '';\n        position: absolute;\n        bottom: 0;\n        left: 0;\n        width: 230px;\n        height: 8px;\n        border-radius: 99px;\n        background: linear-gradient(180deg, #FFE2EB 15.38%, #F892B2 138.46%);\n        z-index: -1;\n\n    }\n\n    /* 右上角粉色线条装饰 */\n    .community-section-wrapper .sparkle {\n        position: absolute;\n        top: -26px;\n        right: -8px;\n        width: 43px;\n        height: 44px;\n    }\n\n    .community-section-wrapper .sparkle img {\n        width: 100%;\n        max-width: 100%;\n    }\n\n    /* 列表项样式 */\n    .community-section-wrapper .feature-list {\n        display: flex;\n        flex-direction: column;\n        gap: 28px;\n        margin-bottom: 32px;\n\n    }\n\n    .community-section-wrapper .feature-item {\n        display: flex;\n        flex-direction: column;\n        align-items: flex-start;\n        gap: 7px;\n    }\n\n    .community-section-wrapper .feature-item svg {\n        width: 32px;\n        height: 32px;\n        flex-shrink: 0;\n\n    }\n\n    .community-section-wrapper .feature-text {\n        display: flex;\n        gap: 10px;\n        align-items: center;\n    }\n\n    .community-section-wrapper .feature-text-title {\n        color: #220509;\n        font-size: 20px;\n        font-weight: 700;\n        line-height: 1.33;\n\n    }\n\n    .community-section-wrapper .feature-text-desc {\n        color: #6D6D6D;\n        font-size: 16px;\n        font-weight: 400;\n        line-height: 1.4;\n        display: flex;\n        align-items: center;\n        gap: 8px;\n        padding: 0 10px;\n    }