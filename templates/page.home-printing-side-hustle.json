    "custom_product_faqs_KHfxNt": {
      "type": "custom-product-faqs",
      "blocks": {
        "faq_tab_jxqEiA": {
          "type": "faq_tab",
          "name": "Q1. What is a DTF printing side business?",
          "settings": {
            "question": "Q1. What is a DTF printing side business?",
            "answer": "<p>A DTF (Direct-to-Film) printing business lets you create custom designs and print on fabrics like cotton, polyester, nylon, and denim. It’s ideal for products like T-shirts, hoodies, and tote bags, offering a great way to earn extra income from home.<br/><br/></p>"
          }
        },
        "faq_tab_za4NG6": {
          "type": "faq_tab",
          "name": "Q2. Do I need experience to start a DTF business?",
          "settings": {
            "question": "Q2. Do I need experience to start a DTF business?",
            "answer": "<p>No. Whether you're a beginner or an experienced maker, DTF printing is user-friendly and easy to learn. We provide resources, guides, and community support to help you get started.</p>"
          }
        },
        "faq_tab_r4At7c": {
          "type": "faq_tab",
          "name": "Q3. How much initial investment is required to start?",
          "settings": {
            "question": "Q3. How much initial investment is required to start?",
            "answer": "<p>The initial investment can range from $2,000 to $5,000, depending on the printer and materials you choose. It’s a low-cost entry for a business that can scale over time.</p>"
          }
        },
        "faq_tab_QrX4Qp": {
          "type": "faq_tab",
          "name": "Q4. How much can I earn from a DTF side business?",
          "settings": {
            "question": "Q4. How much can I earn from a DTF side business?",
            "answer": "<p>Your earnings depend on factors like print volume, pricing, and your target market. On average, a small home-based DTF business can earn anywhere from $500 to $2,000+ per month. The more effort you put in, the more you can grow.</p>"
          }
        },
        "faq_tab_3aEfkf": {
          "type": "faq_tab",
          "name": "Q5. Where can I sell my DTF-printed products?",
          "settings": {
            "question": "Q5. Where can I sell my DTF-printed products?",
            "answer": "<p>You can sell on platforms like Etsy, Instagram, and Facebook. Local markets, custom orders, or even your own website are also great options.</p>"
          }
        },
        "faq_tab_qQ7w39": {
          "type": "faq_tab",
          "name": "Q6. What are some common mistakes to avoid when starting a printing side business?",
          "settings": {
            "question": "Q6. What are some common mistakes to avoid when starting a printing side business?",
            "answer": "<p>Avoid underpricing your products, neglecting marketing, and not maintaining your equipment. Consistency in quality and customer service is key to long-term success.</p>"
          }
        },
        "faq_tab_ADFdg8": {
          "type": "faq_tab",
          "name": "Q7. Do you offer a discount on the printer?",
          "settings": {
            "question": "Q7. Do you offer a discount on the printer?",
            "answer": "<p>Yes. After completing the quiz, you'll receive an exclusive $80 discount on our DTF printers. Also, don’t forget to visit our website regularly for special promotions and limited-time offers on all printers!</p>"
          }
        }
      },
