        img: 'https://www.procolored.com/cdn/shop/files/F13_Pro_0479da75-8ab0-4338-bffa-583a1c04aa8c.png?v=1765786510',
      },
      {
        handle: '13-single-head-dtf-printer-roll',
        id: '49392716448027',
        url: '/products/13-single-head-dtf-printer-roll',
        img: 'https://cdn.shopify.com/s/files/1/0509/3454/6613/files/20260209-153506.png?v=1770622838',
      },
    ];

    const fr = [
      {
        handle: 'imprimante-dtf-k13-lite-13-a3-rose',
        id: '9145801638111',
        url: '/products/imprimante-dtf-k13-lite-13-a3-rose',
        img: 'https://www.procolored.com/cdn/shop/files/K13_lite_pink_10.png?v=1767585182&width=750',
      },
      {
        handle: 'procolored-p13-dtf-printer',
        id: '9090873065695',
        url: '/products/procolored-p13-dtf-printer',
        img: 'https://www.procolored.com/cdn/shop/files/DTF_Printer_Main_4.png?v=1765787950&width=750',
      },
      {
        handle: '13-dual-heads-dtf-pro-a3-dtf-printer-direct-to-film-printer-upgrade',
        id: '9090872148191',
        url: '/products/13-dual-heads-dtf-pro-a3-dtf-printer-direct-to-film-printer-upgrade',
        img: 'https://www.procolored.com/cdn/shop/files/F13_Pro_0479da75-8ab0-4338-bffa-583a1c04aa8c.png?v=1765786510',
      },
      {
        handle: '13-single-head-dtf-printer-roll',
        id: '9090872279263',
        url: '/products/13-single-head-dtf-printer-roll',
        img: 'https://cdn.shopify.com/s/files/1/0509/3454/6613/files/20260209-153506.png?v=1770622838',
      },
    ];

    let productList = [];
    const hostname = window?.location?.hostname || '';

    if (hostname.endsWith('procolored.eu')) {
      productList = eu;
      origin="Shopify_EU";
      discount_value="£70";
      discount_code = 'SIDE80';
    } else if (hostname === 'procolored.com' || hostname === 'www.procolored.com') {
      productList = us;
      origin="Shopify_US";
      discount_value="$80";
      discount_code = 'SIDE80';
    } else if (hostname.startsWith('fr.')) {
      productList = fr;
      origin="Shopify_FR";
      discount_value="€80";
      discount_code = 'SIDE80';
    } else {
      productList = us;
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') e.preventDefault();
    });

    nextBtn.onclick = async () => {
      if (!questions.length) return;

      const q = questions[currentIndex];
      if (!q) return;

      if (!validateCurrentQuestion(q)) return;

      if (currentIndex < questions.length - 1) {
        currentIndex++;
        renderQuestion();
      } else {
        await submitAnswers();
      }
    };

    backBtn.onclick = () => {
      if (!questions.length) return;
      if (currentIndex > 0) {
        currentIndex--;
        renderQuestion();
      }
    };

    loadQuestions();

    function setFooterVisible(visible) {
      const surveyFooter = sectionRoot.querySelector('.footer');
      if (surveyFooter) {
        surveyFooter.style.display = visible ? 'flex' : 'none';
      }
    }

    function setNextButtonText() {
      if (!questions.length) {
        nextBtn.innerText = 'Next question';
        return;
      }
      nextBtn.innerText = currentIndex === questions.length - 1 ? 'Submit' : 'Next question';
    }

    function normalizeHandle(handle) {
      return String(handle || '')
        .trim()
        .replace(/^\/products\//, '')
        .replace(/\?.*$/, '')
        .replace(/^products-/, '');
    }

    function findProductByHandle(handle) {
      const target = normalizeHandle(handle);
      if (!target) return null;

      return (
        productList.find((item) => item.handle === handle) ||
        productList.find((item) => normalizeHandle(item.handle) === target) ||
        productList.find((item) => normalizeHandle(item.handle).includes(target)) ||
        productList.find((item) => target.includes(normalizeHandle(item.handle))) ||
        null
      );
    }

    function escapeHtml(str) {
      return String(str ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function resetQuiz() {
      currentIndex = 0;
      answers = {};
      isResultPage = false;
      quizSessionId = '';
      productHandle = '';
      productTitle = '';
      productUrl = '';
      productImg = '';
      productId = '';

      nextBtn.style.display = 'inline-block';
      {% comment %} backBtn.style.display = 'inline-block'; {% endcomment %}
      nextBtn.disabled = false;
      backBtn.disabled = true;

      setFooterVisible(true);
      renderQuestion();
    }

    function bindCloseBtn() {
      const closeBtn = document.getElementById('closeBtn66');
      if (!closeBtn) return;

      closeBtn.onclick = () => {
        resetQuiz();
      };
    }

    async function loadQuestions() {
      try {
        quizContainer.innerHTML = '<div class="question-title">Loading...</div>';
        nextBtn.disabled = true;
        backBtn.disabled = true;

        const data = await boosterFetch(
          questionsWithOptionsApi,
          {
            origin: origin,
            activityCode: activityCode,
          },
          { method: 'GET' }
        );

        console.log('查询结果:', data);

        if (data.code !== 200) {
          quizContainer.innerHTML = '<div class="question-title">Failed to load questions</div>';
          showToast(data.msg || 'Failed to load questions', 'error');
          return;
        }

        questions = Array.isArray(data.result) ? data.result : [];
        console.log('questions:', questions);

        if (!questions.length) {
          quizContainer.innerHTML = '<div class="question-title">No questions available</div>';
          showToast('No questions found', 'error');
          nextBtn.style.display = 'none';
          backBtn.style.display = 'none';
          return;
        }

        currentIndex = 0;
        answers = {};
        isResultPage = false;

        nextBtn.style.display = 'inline-block';
        {% comment %} backBtn.style.display = 'inline-block'; {% endcomment %}
        nextBtn.disabled = false;
        backBtn.disabled = true;
        setFooterVisible(true);

        renderQuestion();
      } catch (error) {
        console.error('loadQuestions error:', error);
        quizContainer.innerHTML = '<div class="question-title">Failed to load questions</div>';
        showToast('Failed to load questions', 'error');
      } finally {
        setNextButtonText();
      }
    }

    function renderOptionalInput(q) {
      const options = Array.isArray(q?.options) ? q.options : [];
      const opt = options.find((o) => o.optional === 1);
      if (!opt) return '';

      const show = answers[q.id]?.optionIds?.includes(opt.id);

      return `
        <div class="optional-input" style="display:${show ? 'flex' : 'none'}">
          <input
            id="optionalInput-{{ section.id }}"
            placeholder="（Optional）"
            value="${escapeHtml(answers[q.id]?.optionalContent || '')}"
          >
        </div>
      `;
    }

    function isSelected(qId, oId) {
      return !!answers[qId]?.optionIds?.includes(oId);
    }

    function toggleOptionalInput(question) {
      const optionalOption = question.options.find((o) => o.optional === 1);
      if (!optionalOption) return;

      const inputBox = document.querySelector('.optional-input');
      if (!inputBox) return;

      const selected = answers[question.id]?.optionIds?.includes(optionalOption.id);
      inputBox.style.display = selected ? 'flex' : 'none';

      if (!selected && answers[question.id]) {
        answers[question.id].optionalContent = '';
        const input = document.getElementById('optionalInput-{{ section.id }}');
        if (input) input.value = '';
      }
    }

    function bindOptionalInput(question) {
      const input = document.getElementById('optionalInput-{{ section.id }}');
      if (!input) return;

      input.oninput = (e) => {
        if (!answers[question.id]) {
          answers[question.id] = { optionIds: [], optionalContent: '' };
        }
        answers[question.id].optionalContent = e.target.value;
      };
    }

    function bindOptionsNew(question) {
      const selector = question.questionWithPic === 1 ? '.pic-option' : '.option';

      document.querySelectorAll(selector).forEach((el) => {
        el.onclick = () => {
          const optionId = Number(el.dataset.id);
          const currentOption = question.options.find((o) => Number(o.id) === optionId);
          const isOptional = currentOption?.optional === 1;

          if (question.questionType === 'single') {
            document.querySelectorAll(selector).forEach((o) => o.classList.remove('selected'));
            el.classList.add('selected');

            answers[question.id] = {
              optionIds: [optionId],
              optionalContent: isOptional ? answers[question.id]?.optionalContent || '' : '',
            };
          }

          if (question.questionType === 'multi') {
            const data = answers[question.id] || { optionIds: [], optionalContent: '' };

            if (el.classList.contains('selected')) {
              el.classList.remove('selected');
              data.optionIds = data.optionIds.filter((id) => id !== optionId);
            } else {
              const maxSelect = Number(question.maxSelect) || Infinity;
              if (data.optionIds.length >= maxSelect) {
                showToast(`You can select up to ${maxSelect} options`, 'error');
                return;
              }
              el.classList.add('selected');
              data.optionIds.push(optionId);
            }

            const optionalOption = question.options.find((o) => o.optional === 1);
            if (optionalOption && !data.optionIds.includes(optionalOption.id)) {
              data.optionalContent = '';
            }

            answers[question.id] = data;
          }

          toggleOptionalInput(question);
        };
      });

      bindOptionalInput(question);
    }

    function updateProgress() {
      progressInner = document.getElementById('progressInner-{{ section.id }}');
      const progressPercent = document.getElementById('progressPercent-{{ section.id }}');
    
      if (progressInner && questions.length) {
        const percent = Math.round(((currentIndex + 1) / questions.length) * 100);
        progressInner.style.width = percent + '%';
    
        if (progressPercent) {
          progressPercent.textContent = percent + '%';
        }
      }
    }

    function renderQuestion() {
      const q = questions[currentIndex];

      if (!q) {
        quizContainer.innerHTML = '<div class="question-title">No questions available</div>';
        nextBtn.style.display = 'none';
        backBtn.style.display = 'none';
        return;
      }

      const options = Array.isArray(q.options) ? q.options : [];

      const optionHTML =
        q.questionWithPic === 1
          ? `
            <div class="pic-option-list">
              ${options
                .map(
                  (o) => `
                    <div class="pic-option ${isSelected(q.id, o.id) ? 'selected' : ''}" data-id="${o.id}">
                      <div class="pic-wrapper">
                        <img src="${o.optionPic || ''}" alt="${escapeHtml(o.optionText || '')}">
                        <span class="check-mark">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 18 18" fill="none">
                            <path d="M14 0C16.2091 0 18 1.79086 18 4V14C18 16.2091 16.2091 18 14 18H4C1.79086 18 1.61066e-08 16.2091 0 14V4C0 1.79086 1.79086 1.61064e-08 4 0H14ZM14.3477 5.49609C13.9711 5.11994 13.3598 5.11971 12.9834 5.49609L7.99414 10.4854L5.01562 7.50684L4.90723 7.41309C4.52977 7.13337 3.99357 7.16469 3.65137 7.50684C3.27508 7.88321 3.27545 8.49352 3.65137 8.87012L7.28516 12.5049L7.39355 12.5977C7.64769 12.7862 7.9734 12.8328 8.26367 12.7393C8.43176 12.6994 8.59154 12.6155 8.72266 12.4844L14.3477 6.86035L14.4404 6.75195C14.7204 6.37446 14.69 5.8384 14.3477 5.49609Z" fill="black"/>
                          </svg>
                        </span>
                      </div>
                      <div class="pic-text">${escapeHtml(o.optionText || '')}</div>
                    </div>
                  `
                )
                .join('')}
            </div>
          `
          : options
              .map(
                (o) => `
                  <div class="option ${isSelected(q.id, o.id) ? 'selected' : ''}" data-id="${o.id}">
                    ${escapeHtml(o.optionText || '')}
                  </div>
                `
              )
              .join('');

      quizContainer.innerHTML = `
        <div class="modal-header">
          <div class="modal-header-title">Question ${q.questionNo || currentIndex + 1}/${questions.length}</div>
        </div>
        <div class="progress-bar">
          <div class="progress-inner" id="progressInner-{{ section.id }}">
          <span class="progress-percent" id="progressPercent-{{ section.id }}">0%</span>
          </div>
        </div>
        <div class="question-title">${escapeHtml(q.questionTitle || '')}</div>
        ${optionHTML}
        ${renderOptionalInput(q)}
      `;

      bindOptionsNew(q);
      bindCloseBtn();

      backBtn.disabled = currentIndex === 0;
      setNextButtonText();
      updateProgress();
    }

    function validateCurrentQuestion(q) {
      if (!q || !q.required) return true;

      const answer = answers[q.id];
      const optionIds = Array.isArray(answer?.optionIds) ? answer.optionIds : Array.isArray(answer) ? answer : [];

      if (!optionIds.length) {
        showToast('Please select at least one option', 'error');
        return false;
      }

      return true;
    }

    function buildSubmitData() {
      const list = [];

      Object.keys(answers).forEach((qId) => {
        const item = answers[qId];
        const optionIds = Array.isArray(item?.optionIds) ? item.optionIds : Array.isArray(item) ? item : [];

        optionIds.forEach((optId) => {
          const dto = {
            questionId: Number(qId),
            optionId: Number(optId),
          };

          if (item?.optionalContent) {
            dto.optionalContent = item.optionalContent;
          }

          list.push(dto);
        });
      });

      return {
        quizSubmitAnswerDTOList: list,
      };
    }

    async function submitAnswers() {
      const payload = buildSubmitData();

      if (!payload.quizSubmitAnswerDTOList.length) {
        showToast('Please complete the quiz before submitting', 'error');
        return;
      }

      try {
        nextBtn.disabled = true;
        backBtn.disabled = true;
        nextBtn.innerText = 'Submitting...';

        const data = await boosterFetch(
          saveUserAnswersApi,
          {
            ...payload,
            origin: origin,
          },
          { method: 'POST' }
        );

        console.log('提交答案返回查询结果:', data);

        if (data.code !== 200) {
          showToast(data.msg || 'Failed to submit answers', 'error');
          return;
        }

        quizSessionId = data.result?.sessionId || '';
        productHandle = data.result?.handle || '';
        productTitle = data.result?.recommendedProduct || '';

        const productObj = findProductByHandle(productHandle);

        productUrl =
          productObj?.url ||
          data.result?.productUrl ||
          (productHandle ? `/products/${normalizeHandle(productHandle)}` : '');

        productImg = productObj?.img || data.result?.productImg || '';
        productId = productObj?.id || data.result?.productId || '';

        renderResult();
      } catch (error) {
        console.error('submitAnswers error:', error);
        showToast('Failed to submit answers', 'error');
      } finally {
        if (!isResultPage) {
          nextBtn.disabled = false;
          backBtn.disabled = currentIndex === 0;
          setNextButtonText();
        }
      }
    }

    function renderResult() {
      isResultPage = true;

      const safeProductTitle = escapeHtml(productTitle || 'Recommended Product');
      const safeProductImg = productImg || '';
      const safeProductUrl = productUrl || '#';
      const hasProductId = !!productId;
      const hasProductUrl = safeProductUrl && safeProductUrl !== '#';

      const buyNowHtml = hasProductId
        ? `
          <div class="result-product-button-buy-now">
            <product-card>
              <div
                class="product-btn external-add-to-cart-button product-card--add-to-cart-button product-card--add-to-cart-button-simple button accent"
                data-product-id="${productId}"
                tabindex="-1"
              >
                <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                  <circle class="spinner-path" fill="none" stroke-width="6" cx="33" cy="33" r="30" stroke="var(--color-body)"></circle>
                </svg>
                <span class="product-card--add-to-cart-text">Buy Now</span>
              </div>
            </product-card>
          </div>
        `
        : hasProductUrl
        ? `
          <div class="result-product-button-buy-now">
            <div class="result-product-button-learn-more" id="buyNowBtn-{{ section.id }}">Buy Now</div>
          </div>
        `
        : '';

      quizContainer.innerHTML = `
        <div class="result-title">Congratulations!</div>
        <div class="result-subtitle">You've unlocked your dream printer!</div>
        <div class="result-desc">
          Get exclusive savings of <span>${discount_value}</span> with your discount code below.
        </div>

        <div class="result-product-container">
          <div class="result-product-img">
            <img src="${safeProductImg}" alt="${safeProductTitle}">
          </div>
          <div class="result-product-content">
            <div class="result-product-title">${safeProductTitle}</div>
            <div class="coupon-box">
              <div class="coupon-code">
                ${discount_value} Discount Code: <div id="couponText-{{ section.id }}">${discount_code}</div>
              </div>
              <button class="copy-btn" id="copyBtn-{{ section.id }}" type="button">COPY</button>
            </div>
            <div class="result-product-button-group">
              ${hasProductUrl ? `<div class="result-product-button-learn-more" id="learnMoreBtn-{{ section.id }}">Learn More</div>` : ''}
              ${buyNowHtml}
            </div>
          </div>
        </div>





        <div class="email-tips">
          Enter your email to receive the ${discount_value} discount and more offers！
        </div>

        <div class="email-box">
          <input type="email" id="emailInput-{{ section.id }}" placeholder="Enter your email" />
          <button id="emailSubmitBtn-{{ section.id }}" type="button">Submit</button>
        </div>

        <div class="notes-container">
          <div class="notes-title">Notes</div>
          <div class="notes-desc">1.One discount code per email.</div>
          <div class="notes-desc">2.The discount code is valid for 60 days.</div>
          <div class="notes-desc">3.Applied to the printers only.</div>
          <div class="notes-desc">4.This discount code cannot be combined with other discount codes.</div>
        </div>

      `;

      nextBtn.style.display = 'none';
      backBtn.style.display = 'none';
      setFooterVisible(false);
      progressInner = null;

      const learnMoreBtn = document.getElementById('learnMoreBtn-{{ section.id }}');
      if (learnMoreBtn && hasProductUrl) {
        learnMoreBtn.onclick = () => window.open(safeProductUrl, '_blank');
      }

      const buyNowBtn = document.getElementById('buyNowBtn-{{ section.id }}');
      if (buyNowBtn && hasProductUrl) {
        buyNowBtn.onclick = () => window.open(safeProductUrl, '_blank');
      }

      const copyBtn = document.getElementById('copyBtn-{{ section.id }}');
      if (copyBtn) {
        copyBtn.onclick = async () => {
          try {
            await navigator.clipboard.writeText(discount_code);
            showToast('Copied', 'success');
          } catch (error) {
            const textNode = document.getElementById('couponText-{{ section.id }}');
            if (textNode) {
              const range = document.createRange();
              range.selectNodeContents(textNode);
              const selection = window.getSelection();
              selection.removeAllRanges();
              selection.addRange(range);
            }
            showToast('Coupon code selected', 'success');
          }
        };
      }

      const emailSubmitBtn = document.getElementById('emailSubmitBtn-{{ section.id }}');
      const emailInput = document.getElementById('emailInput-{{ section.id }}');

      if (emailSubmitBtn) {
        emailSubmitBtn.onclick = submitEmail;
      }

      if (emailInput) {
        emailInput.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            submitEmail();
          }
        });
      }

      bindCloseBtn();
    }

    async function submitEmail() {
      const emailInput = document.getElementById('emailInput-{{ section.id }}');
      const submitBtn = document.getElementById('emailSubmitBtn-{{ section.id }}');
      if (!emailInput || !submitBtn) return;

      const email = emailInput.value.trim();
      const reg = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!reg.test(email)) {
        showToast('Please enter a valid email address', 'error');
        return;
      }

      if (!quizSessionId) {
        showToast('Session expired, please retry', 'error');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.classList.add('loading');
      submitBtn.innerText = 'Submitting...';

      try {
        const data = await boosterFetch(
          submitEmailApi,
          {
            sessionId: quizSessionId,
            email,
            origin: origin,
          },
          { method: 'POST' }
        );

        console.log('邮箱提交结果:', data);

        if (data.code === 200) {
          showToast('Email submitted successfully 🎉', 'success');
          submitBtn.innerText = 'Submitted';
          submitBtn.disabled = true;
          emailInput.disabled = true;
        } else {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Submit';
          showToast(data.msg || 'Submit failed', 'error');
        }
      } catch (error) {
        console.error('submitEmail error:', error);
        submitBtn.disabled = false;
        submitBtn.innerText = 'Submit';
        showToast('Network error, please retry', 'error');
      } finally {
        submitBtn.classList.remove('loading');
        if (submitBtn.innerText !== 'Submitted') {
          submitBtn.innerText = 'Submit';
        }
      }
    }

    function showToast(text, type = 'success') {
      let toast = document.getElementById('quizToast-{{ section.id }}');

      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'quizToast';

        const modalContainer = sectionRoot.querySelector('.modal-container');
        if (modalContainer) {
          modalContainer.appendChild(toast);
        } else {
          document.body.appendChild(toast);
        }
      }

      toast.innerHTML = `
        <span class="toast-icon">${type === 'success' ? '✓' : '✕'}</span>
        <span class="toast-text">${escapeHtml(text)}</span>
      `;

      toast.className = `quiz-toast show ${type}`;

      clearTimeout(toast.timer);
      toast.timer = setTimeout(() => {
        toast.className = 'quiz-toast';
      }, 2500);
    }
  })();
  });
</script>
