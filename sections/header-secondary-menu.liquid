{%- liquid
  assign menu = section.settings.secondary_menu
  assign show_language_switcher = section.settings.show_language_switcher
  assign show_currency_switcher = section.settings.show_currency_switcher
  assign show_social_media = section.settings.show_social_media
  assign show_country_switcher = section.settings.show_country_switcher
  assign color_secondary_menu_bg = settings.color_secondary_menu_bg | downcase
  assign color_header_bg = settings.color_header_bg | downcase

  assign has_border = false
  if color_header_bg == color_secondary_menu_bg
    assign has_border = true
  endif
-%}
{{- 'subheader.css' | asset_url | stylesheet_tag -}}
<style>
  .subheader--inner .subheader--right > .country-switcher-footer {
    margin-top: 0;
  }
  .subheader--inner .subheader--right > .country-switcher-footer .country-switcher-footer-icon {
    width: 20px;
    height: 20px;
  }
  .subheader--inner .subheader--right > .country-switcher-footer .country-switcher-footer-country-name {
    font-size: 12px;
    color: #000;
    line-height: 20px;
  }
</style>
<aside class="subheader subheader-border--{{ has_border }}">
  <div class="subheader--inner">
    <div class="subheader--left">
      <ul class="thb-full-menu" role="menubar">
        {%- for link in menu.links -%}
          {%- liquid
            assign has_sub_menu = false
            assign has_mega_menu = false

            if link.links.size > 0
              assign has_sub_menu = true
            endif
          -%}
          <li
            role="menuitem"
            class="{% if has_sub_menu %}menu-item-has-children{% endif %}{% if has_mega_menu %} menu-item-has-megamenu{% endif %}{% if link.active %} active{% endif %}"
            {% if has_sub_menu %}
              data-item-title="{{ link.title | escape }}"
            {% endif %}
          >
            <a
              href="{{ link.url }}"
              title="{{ link.title | escape }}"
              {%- if link.active %}
                aria-current="page"
              {% endif -%}
            >
              {{- link.title -}}
              {%- if has_sub_menu -%}{%- render 'svg-icons' with 'thb-dropdown-bottom' -%}{%- endif -%}
            </a>
            {%- if has_sub_menu == true -%}
              <ul class="sub-menu" tabindex="-1">
                {%- for l in link.links -%}
                  {%- liquid
                    assign has_sub_menu = false
                    assign has_mega_menu = false
                    if l.links.size > 0
                      assign has_sub_menu = true
                    endif
                  -%}
                  <li
                    class="{%- if l.active %}active{% endif %}{% if has_sub_menu %} menu-item-has-children{%- endif -%}"
                    role="none"
                    {% if has_sub_menu %}
                      data-item-title="{{ l.title | escape }}"
                    {% endif %}
                  >
                    <a href="{{ l.url }}" title="{{ l.title | escape }}" role="menuitem">
                      {{- l.title -}}
                      {%- if has_sub_menu -%}{%- render 'svg-icons' with 'thb-dropdown-right' -%}{%- endif -%}
                    </a>
                    {%- if has_sub_menu -%}
                      <ul class="sub-menu" role="menu">
                        {%- for sub_link in l.links -%}
                          <li class="{%- if sub_link.active %} active{% endif %}" role="none">
                            <a href="{{ sub_link.url }}" title="{{ sub_link.title | escape }}" role="menuitem">
                              {{- sub_link.title -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="subheader--right">
      {%- liquid
        if show_social_media
          render 'social-links', show_label: false
        endif
      -%}
      <div class="no-js-hidden">
        {%- render 'localization',
          id: 'HeaderLocalization',
          show_language_switcher: show_language_switcher,
          show_currency_switcher: show_currency_switcher
        -%}
      </div>
      {% comment %}
        {%- liquid
          if show_country_switcher
            render 'country-switcher'
          endif
        -%}
      {% endcomment %}
      {% if show_country_switcher %}
        <div class=" country-switcher-footer">
          <div class="country-switcher-footer-icon">
            <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none">
              <g clip-path="url(#prefix__clip0_6956_12946)"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9h-5.4M12 21a9 9 0 01-9-9m9 9c1.988 0 3.6-4.03 3.6-9M12 21c-1.988 0-3.6-4.03-3.6-9M3 12a9 9 0 019-9m-9 9h5.4M12 3c-1.988 0-3.6 4.03-3.6 9M12 3c1.988 0 3.6 4.03 3.6 9m0 0H8.4" stroke="currentColor" stroke-width="1.5"></path></g><defs><clipPath id="prefix__clip0_6956_12946"><path fill="currentColor" d="M0 0h24v24H0z"></path></clipPath></defs>
            </svg>
          </div>
          <div class="country-switcher-footer-country-name"></div>
          {% comment %} {% render 'country-switcher' %} {% endcomment %}
        </div>
      {% endif %}
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Secondary Menu",
  "class": "header-secondary-menu-section",
  "settings": [
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary menu"
    },
    {
      "type": "header",
      "content": "Language switcher"
    },
    {
      "type": "checkbox",
      "id": "show_language_switcher",
      "label": "Enable language switcher",
      "default": false,
      "info": "To add a language, go to your [language settings](/admin/settings/languages)."
    },
    {
      "type": "header",
      "content": "Currency switcher"
    },
    {
      "type": "checkbox",
      "id": "show_currency_switcher",
      "label": "Enable currency switcher",
      "default": true,
      "info": "To add a country/region, go to your [payment settings](/admin/settings/payments)."
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social_media",
      "label": "Show social media",
      "default": true
    },
    {
      "type": "header",
      "content": "国家切换"
    },
    {
      "type": "checkbox",
      "id": "show_country_switcher",
      "label": "显示国家切换",
      "default": true
    }
  ]
}
{% endschema %}
