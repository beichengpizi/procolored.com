{% comment %} <div>
    <div class="globo-formbuilder" data-id="MTM5NDQx"></div>
</div> {% endcomment %}
<style>
  .video-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 50px auto;
  }

  video {
    width: 100%;
    display: block;
    max-height: 400px;
  }

  .progress-bar {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 5px;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .progress {
    width: 0;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.8);
  }

  .skip-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin: 20px 0;
    display: none; /* 初始隐藏 */
  }

  .skip-container.mobile {
    grid-template-columns: repeat(2, 1fr);
  }

  .skip-item {
    background-color: #ddd;
    padding: 20px;
    text-align: center;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .skip-item:hover {
    background-color: #ccc;
  }

  @media (max-width: 600px) {
    .video-container {
      max-width: 100%;
    }

    .skip-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="video-container" id="video-container">
  <!-- 第一个视频 -->
  {%- for block in section.blocks -%}
    {% if block.settings.required %}
        <video id="video{{ forloop.index }}" class="video" controls style="display: none;">
            <source src="{{ block.settings.video.sources[0].url }}" type="video/mp4">
            Your browser does not support the video tag.
        </video>
    {% endif %}
  {%- endfor -%}
  <!-- 控制条 -->
  <div class="progress-bar">
    <div class="progress" id="progress"></div>
  </div>
</div>

<!-- 可跳过的视频网格 -->
<div class="skip-container" id="skip-container">
  {%- for block in section.blocks -%}
    {%- if block.settings.required == false -%}
        <div class="skip-item">
            <video class="video" controls>
                <source src="{{ block.settings.video.sources[0].url }}" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  // 获取所有视频元素
  const videos = Array.from(document.querySelectorAll('.video'));

  let currentVideoIndex = 0;

  // 禁用进度条拖动
  function disableProgressBar() {
    const video = videos[currentVideoIndex];
    const progressBar = document.getElementById('progress');
    video.addEventListener('timeupdate', () => {
      const percentage = (video.currentTime / video.duration) * 100;
      progressBar.style.width = `${percentage}%`;
    });
  }

  // 自动播放下一个视频
  function playNextVideo() {
    const video = videos[currentVideoIndex];
    video.addEventListener('ended', () => {
      if (currentVideoIndex < videos.length - 1) {
        // 隐藏当前视频
        video.style.display = 'none';
        currentVideoIndex++;
        // 显示下一个视频
        videos[currentVideoIndex].style.display = 'block';
        videos[currentVideoIndex].play();
      } else {
        // 所有视频播放完毕，隐藏视频区域并显示跳过视频网格
        document.getElementById('video-container').style.display = 'none';
        document.getElementById('skip-container').style.display = 'grid';
      }
    });
  }

  // 初始化视频和进度条
  function initVideos() {
    // 显示第一个视频
    videos[0].style.display = 'block';
    disableProgressBar(); // 禁用进度条拖动
    playNextVideo(); // 自动播放下一个视频
  }

  // 初始化
  initVideos();
</script>
{% schema %}
  {
    "name": "Warranty Form",
    "tag": "section",
    "settings": [
      
    ],
    "blocks": [
        {
            "type": "video",
            "name": "video",
            "settings": [
                {
                    "type": "video",
                    "id": "video",
                    "label": "Video"
                },
                {
                    "type": "checkbox",
                    "id": "required",
                    "label": "Required"
                }
            ]
        }
    ],
    "presets": [
      {
        "name": "Warranty Form"
      }
    ]
  }
{% endschema %}