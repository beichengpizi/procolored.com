<style>
  #shopify-section-{{ section.id }} {
    padding: 80px 0;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .fw-herounit-title {
    color: #121212;
    font-size: 40px;
    font-weight: 800;
