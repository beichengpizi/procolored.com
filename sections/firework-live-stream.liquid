  }

  #shopify-section-{{ section.id }} .live-stream-date {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  #shopify-section-{{ section.id }} .live-stream-button {
    border-radius: 8px;
    background: #2B7FFF;
    padding: 12px;
    color: #FFF;
    font-size: 16px;
    font-weight: 700;
    line-height: 24px; /* 150% */
