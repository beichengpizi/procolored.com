  }

  #shopify-section-{{ section.id }} .hidden {
    display: none;
  }

  #shopify-section-{{ section.id }} .fw-herounit-left {
    position: relative;
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .fw-herounit-left img {
