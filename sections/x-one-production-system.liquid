{% comment %} 统一所有slide高度，以第一个slide为最高，采用JS动态设定高度。 {% endcomment %}
<style>
    .x-one-production-system-{{ section.id }}{
      background: #000;
      padding-top:{{ section.settings.padding_top }}px;
      padding-bottom:{{ section.settings.padding_bottom }}px;
      overflow: hidden;
    }
    /* 外部容器：最大 1200px */
    .x-one-production-system-{{ section.id }} .main-wrapper {
      width: 100%;
      max-width: 1000px;
      margin: 0 auto;
      position: relative;
    }

    .swiper-container-{{ section.id }} {
      overflow: visible;
      width: 100%;
    }

    /* --- 核心布局修改 --- */
    .x-one-production-system-{{ section.id }} .swiper-slide {
      width: 1000px !important;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      /* 高度由JS统一动态设置 */
      /* min-height: var(--xone-slide-max-height, auto); */
      box-sizing: border-box;
    }
    @media screen and (max-width: 1600px){
      .x-one-production-system-{{ section.id }} .swiper-slide {
        width: 1000px !important;
      }
    }
    @media screen and (max-width: 1400px){
      .x-one-production-system-{{ section.id }} .swiper-slide {
        width: 960px !important;
      }
    }
    .x-one-production-system-{{ section.id }} .swiper-slide-active {
      z-index: 10;
    }
    .x-one-production-system-{{ section.id }} .text-area-container{
    position: relative;
    min-height: 190px;
    padding: 0 24px;
  }
    .x-one-production-system-{{ section.id }} .text-area {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      text-align: center;
      color: #fff;
      width: 100%;
      margin-bottom: 0;
      box-sizing: border-box;
      opacity: 0;
      position: absolute;
      z-index: -1;
      top: 0;
      left: 0;


    }

    .x-one-production-system-{{ section.id }} .slide-title {
      color: #FF8F1C;
      text-align: center;
      font-size: 48px;
      font-style: normal;
      font-weight: 800;
      line-height: 120%; /* 69.6px */
      max-width: 855px;
      margin: 0 auto;
    }

    .x-one-production-system-{{ section.id }} .slide-desc {
      color: #898A8E;
      text-align: center;
      font-size: 18px;
      font-weight: 400;
      line-height: 150%;
      max-width: 840px;
      width: 100%;
    }

    .x-one-production-system-{{ section.id }} .media-container {
      width: 100%;
      height: 560px;
      border-radius: 20px;
      overflow: hidden;
      background: #1a1a1a;
      position: relative;
    }
    .x-one-production-system-{{ section.id }} .media-content.pc{
      display: block;
    }
    .x-one-production-system-{{ section.id }} .media-content.mb{
      display: none;
    }
    .x-one-production-system-{{ section.id }} .media-content {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .x-one-production-system-{{ section.id }} .custom-controls-nav {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin-top: 32px;
      align-items: center;
      border-bottom: 1px solid #898A8E;
      width: max-content;
      margin-left: auto;
      margin-right: auto;
    }
    .x-one-production-system-{{ section.id }} .nav-btn-new {
      color: #898A8E;
      text-align: center;
      font-size: 18px;
      font-style: normal;
      font-weight: 500;
      line-height: 120%; /* 21.6px */
      padding-bottom: 12px;
      position: relative;
      cursor: pointer;
    }
    .x-one-production-system-{{ section.id }} .nav-btn-new.active {
      color: #FFF;
      font-size: 18px;
      font-weight: 700;
    }
    .x-one-production-system-{{ section.id }} .nav-btn-new.active::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -1px;
      width: 100%;
      height: 3px;
      border-radius: 2px;
      background: #FF8F1C;
    }
    .x-one-production-system-{{ section.id }} .custom-controls {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 30px;
      align-items: center;
    }

    .x-one-production-system-{{ section.id }} .nav-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.30);;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      position: relative;
      transition: background 0.3s;
    }

    .x-one-production-system-{{ section.id }} .nav-btn:hover {
      background: #555;
    }

    .x-one-production-system-{{ section.id }} .arrow {
      border: solid #fff;
      border-width: 0 2px 2px 0;
      display: inline-block;
      padding: 3px;
    }

    .x-one-production-system-{{ section.id }} .arrow-left {
      transform: rotate(135deg);
      margin-left: 2px;
    }

    .x-one-production-system-{{ section.id }} .arrow-right {
      transform: rotate(-45deg);
      margin-right: 2px;
    }

    .x-one-production-system-{{ section.id }} .nav-btn.next {
      background: #fff;
    }

    .x-one-production-system-{{ section.id }} .nav-btn.next .arrow {
      border-color: #000;
    }

    .x-one-production-system-{{ section.id }} .nav-btn.next:hover {
      background: #e0e0e0;
    }

    .x-one-production-system-{{ section.id }} .progress-ring {
      position: absolute;
      top: 0;
      left: 0;
      width: 40px;
      height: 40px;
      transform: rotate(-90deg);
      pointer-events: none;
    }

    .x-one-production-system-{{ section.id }} .progress-ring__circle {
      stroke: #FF8F1C;
      stroke-width: 2;
      fill: transparent;
      r: 19;
      cx: 20;
      cy: 20;
      stroke-dasharray: 144.5;
      stroke-dashoffset: 144.5;
      transition: stroke-dashoffset linear;
    }
    @media screen and (max-width: 768px) {
      .x-one-production-system-{{ section.id }}{
        padding-top:{{ section.settings.padding_top_mobile }}px;
        padding-bottom:{{ section.settings.padding_bottom_mobile }}px;
        overflow: hidden;
      }
      .swiper-container-{{ section.id }} {
        overflow: hidden;
         padding: 0 24px;

      }
      .x-one-production-system-{{ section.id }} .text-area-container{
        position: relative;
        min-height: 179px;
        padding: 0 24px;
      }
      .x-one-production-system-{{ section.id }} .text-area {
        align-items: start;
        gap: 12px;
        text-align: left;
        padding: 0;
        margin-bottom:0;
      }
      .x-one-production-system-{{ section.id }} .swiper-slide {
        width: 100% !important;
        opacity: 1;
      }
      .x-one-production-system-{{ section.id }} .slide-title {
        font-size: 26px;
        text-align: left;
        max-width:100%;
        margin: 0;
      }
      .x-one-production-system-{{ section.id }} .slide-desc {
        font-size: 14px;
        text-align: left;
        max-width:100%;
        {% comment %} min-height: 126px; {% endcomment %}
      }
      .x-one-production-system-{{ section.id }} .custom-controls {
        gap: 15px;
        margin-top: 24px;
      }
      .x-one-production-system-{{ section.id }} .media-container {
        border-radius: 10px;
        height:215px;
      }
      .x-one-production-system-{{ section.id }} .media-content.pc{
        display: none;
      }
      .x-one-production-system-{{ section.id }} .media-content.mb{
        display: block;
      }
      .x-one-production-system-{{ section.id }} .custom-controls-nav {
        display: flex;
        justify-content: space-between;
        gap:0;
        margin-top: 20px;
        align-items: center;
        border-bottom: 1px solid #898A8E;
        width: max-content;
        margin-left: 24px;
        margin-right: 24px;
        width: calc(100% - 48px);
      }
      .x-one-production-system-{{ section.id }} .nav-btn-new {

        font-size: 14px;

      }
      .x-one-production-system-{{ section.id }} .nav-btn-new.active {
        font-size: 14px;

      }
      .x-one-production-system-{{ section.id }} .nav-btn-new.active::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -1px;
        width: 100%;
        height: 3px;
        border-radius: 2px;
        background: #FF8F1C;
      }
    }
</style>

<div
  id="{% if section.settings.nav_id != empty %}custom-nav-{{ section.settings.nav_id }}{% endif %}"
  class="x-one-production-system-{{ section.id }}"
>
  <div class="main-wrapper">
    <div class="text-area-container">
      {% for block in section.blocks %}
        {%- assign heading = block.settings.heading -%}
        {%- assign subheading = block.settings.subheading -%}
        <div class="text-area">
          <div class="slide-title">{{- heading -}}</div>
          <div class="slide-desc">
            {{- subheading -}}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="swiper-container swiper-container-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'image' %}
              {%- assign heading = block.settings.heading -%}
              {%- assign subheading = block.settings.subheading -%}
              {%- assign desktop_img = block.settings.image -%}
              {%- assign mobile_img = block.settings.mobile_image | default: desktop_img -%}
              <div class="swiper-slide" data-type="image" data-duration="5000">
                {% comment %}
                  <div class="text-area">
                    <div class="slide-title">{{- heading -}}</div>
                    <div class="slide-desc">
                      {{- subheading -}}
                    </div>
                  </div>
                {% endcomment %}
                <!-- 媒体部分在下 (圆角) -->
                <div class="media-container">
                  <img
                    data-sizes="80vw"
                    data-srcset="
                      {% if desktop_img.width >= 375 %}{{ desktop_img | image_url: width: 750 }} 375w,{% endif %}
                      {% if desktop_img.width >= 750 %}{{ desktop_img | image_url: width: 1500 }} 750w,{% endif %}
                      {% if desktop_img.width >= 1100 %}{{ desktop_img | image_url: width:2200 }} 1100w,{% endif %}
                      {% if desktop_img.width >= 1500 %}{{ desktop_img | image_url: width: 3000 }} 1500w,{% endif %}
                      {% if desktop_img.width >= 1780 %}{{ desktop_img | image_url: width: 3500 }} 1780w,{% endif %}
                      {% if desktop_img.width >= 2000 %}{{ desktop_img | image_url: width: 4000 }} 2000w,{% endif %}
                      {% if desktop_img.width >= 3000 %}{{ desktop_img | image_url: width: 3000 }} 3000w,{% endif %}
                      {% if desktop_img.width >= 3840 %}{{ desktop_img | image_url: width: 3840 }} 3840w,{% endif %}
                      {{ desktop_img | image_url }} {{ desktop_img.width }}w
                    "
                    data-src="{{ desktop_img | image_url: width: 1500 }}"
                    style="max-width:100%;width:100%;aspect-ratio:{{ desktop_img.aspect_ratio }};"
                    class="lazyload pc media-content"
                    alt="{{ block.settings.heading | strip_html | truncate: 30 | default: 'Feature Image' }}"
                  >
                  <img
                    data-sizes="100vw"
                    data-srcset="
                      {% if mobile_img.width >= 100 %}{{ mobile_img | image_url: width: 200 }} 375w,{% endif %}
                      {% if mobile_img.width >= 200 %}{{ mobile_img | image_url: width: 400 }} 375w,{% endif %}
                        {% if mobile_img.width >= 375 %}{{ mobile_img | image_url: width: 750 }} 375w,{% endif %}
                        {% if mobile_img.width >= 750 %}{{ mobile_img | image_url: width: 1500 }} 750w,{% endif %}
                        {% if mobile_img.width >= 1100 %}{{ mobile_img | image_url: width:2200 }} 1100w,{% endif %}
                        {% if mobile_img.width >= 1500 %}{{ mobile_img | image_url: width: 3000 }} 1500w,{% endif %}
                        {{ mobile_img | image_url }} {{ mobile_img.width }}w
                    "
                    data-src="{{ mobile_img | image_url: width: 400 }}"
                    style="max-width:100%;width:100%;aspect-ratio:{{ mobile_img.aspect_ratio }};"
                    class="lazyload mb media-content"
                    alt="{{ block.settings.heading | strip_html | truncate: 30 | default: 'Feature Image' }}"
                  >
                </div>
              </div>

            {% when 'shopifyVideo' %}
              {%- assign heading = block.settings.heading -%}
              {%- assign subheading = block.settings.subheading -%}
              {% assign video_pc = block.settings.video_pc %}
              {% assign video_mb = block.settings.video_mb %}
              {% assign video_poster_pc = block.settings.video_poster_pc | default: video_pc.preview_image %}
              <div class="swiper-slide" data-type="video">
                {% comment %}
                  <div class="text-area">
                    <div class="slide-title">{{- heading -}}</div>
                    <div class="slide-desc">
                      {{- subheading -}}
                    </div>
                  </div>
                {% endcomment %}
                <div class="media-container">
                  {% comment %}
                    <video class="media-content" muted playsinline style="background: #000;">
                      <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
                    </video>
                  {% endcomment %}
                  <video
                    class="media-content"
                    muted
                    loop
                    playsinline
                    webkit-playsinline
                    x5-playsinline
                    x5-video-player-type="h5"
                    x-webkit-airplay="allow"
                    style="background: #000;aspect-ratio:{{ video_poster_pc.aspect_ratio }};"
                    poster-pc="{{ video_poster_pc | image_url: width: 700 }}"
                  >
                    {% for source in video_pc.sources %}
                      <source src="{{ source.url }}" type="{{source.mime_type }}" media="(min-width: 769px)">
                    {% endfor %}
                    {% for source in video_mb.sources %}
                      <source src="{{ source.url }}" type="{{source.mime_type }}" media="(max-width: 769px)">
                    {% endfor %}
                    Your browser does not support the video tag.
                  </video>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
        <!-- 省略注释示例slide，非实际渲染内容 -->
      </div>
    </div>
    <div class="custom-controls-nav">
      {% for block in section.blocks %}
        {%- assign nav_title = block.settings.nav_title | default: 'tab' -%}
        <div class="nav-btn-new{% if forloop.first %} active{% endif %}">
          {{ nav_title }}
        </div>
      {% endfor %}
    </div>
    <!-- 底部导航 -->
    {% comment %}
      <div class="custom-controls">
        <div class="nav-btn prev" id="btnPrev">
          <i class="arrow arrow-left"></i>
        </div>
        <div class="nav-btn next" id="btnNext">
          <!-- SVG 进度条 -->
          <svg class="progress-ring">
            <circle class="progress-ring__circle" id="progressCircle" />
          </svg>
          <i class="arrow arrow-right"></i>
        </div>
      </div>
    {% endcomment %}
  </div>
</div>

{% comment %}
  增加功能: 当点击到最后一个时可以继续点击，并回到第一个。保留注释。
  如下修改：
  - next按钮始终可点击（去除尾部禁用逻辑）
  - 点击next且到最后一张时，自动切回第一张（slideTo(0)）
  - 更新进度和导航逻辑以适配循环行为
  - 保持prev按钮在第一个时禁用
{% endcomment %}
{% comment %}
  - PC端: 鼠标上下滚动切换slide，使用ScrollTrigger.min.js实现
  - 移动端: 保持原有自动切换（定时下一张、支持触摸切换）
  - 按需引入gsap/ScrollTrigger.min.js，比如：<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
{% endcomment %}
<script>
  window.addEventListener('DOMContentLoaded', () => {
    // --- 1. 基础变量与高宽同步 ---
    const progressCircle = document.querySelector('.x-one-production-system-{{ section.id }} #progressCircle');
    const btnPrev = document.querySelector('.x-one-production-system-{{ section.id }} #btnPrev');
    const btnNext = document.querySelector('.x-one-production-system-{{ section.id }} #btnNext');
    const circumference = 2 * Math.PI * 23;
    let timer = null;
    let currentVideo = null;
    let lastDirection = 'right';
    let scrollLock = false; // PC滚动切换节流锁

    // 统一slide高度
    function setUnifiedSlideHeight() {
      const slides = document.querySelectorAll('.x-one-production-system-{{ section.id }} .swiper-slide');
      let maxHeight = 0;
      slides.forEach((slide) => {
        slide.style.minHeight = 'unset';
        slide.style.height = 'auto';
        const rect = slide.getBoundingClientRect();
        const actualHeight = slide.offsetHeight || rect.bottom - rect.top;
        if (actualHeight > maxHeight) maxHeight = actualHeight;
      });
      slides.forEach((slide) => {
        slide.style.minHeight = maxHeight + 'px';
      });
    }
    if (typeof window.requestAnimationFrame === 'function') {
      requestAnimationFrame(setUnifiedSlideHeight);
    } else {
      setTimeout(setUnifiedSlideHeight, 100);
    }
    window.addEventListener('resize', setUnifiedSlideHeight);
    setTimeout(setUnifiedSlideHeight, 500);

    if (progressCircle) {
      progressCircle.style.strokeDasharray = `${circumference} ${circumference}`;
      progressCircle.style.strokeDashoffset = circumference;
    }

    // 样式和动画
    const setSlideTitleAnimated = (swiper, direction) => {
      const activeSlide = swiper.slides[swiper.activeIndex];
      if (activeSlide) {
        const titles = document.querySelectorAll('.x-one-production-system-{{ section.id }} .text-area');
        const title = titles && titles.length > swiper.activeIndex ? titles[swiper.activeIndex] : titles[0];
        if (title) {
          title.classList.remove('fadeIn', 'animated');
          const anim = direction === 'left' ? 'fadeIn' : 'fadeIn';
          title.classList.add('animated', anim);
          title.style.opacity = '1';
          title.style.position = "relative";
          title.style.zIndex = 3;
          // Add margin-bottom for PC (32px) and mobile (20px)
          if(window.innerWidth <= 768) {
            title.style.marginBottom = '20px';
          } else {
            title.style.marginBottom = '32px';
          }
       
        }
      }
    };

    // Swiper初始化（PC禁止鼠标/触摸拖拽, 移动开启触摸/自动切换）
    // 获取所有自定义导航按钮
    const navBtns = document.querySelectorAll('.x-one-production-system-{{ section.id }} .custom-controls-nav .nav-btn-new');

    const mySwiper = new Swiper('.x-one-production-system-{{ section.id }} .swiper-container', {
      slidesPerView: 'auto',
      centeredSlides: true,
      spaceBetween: 20,
      allowTouchMove: window.innerWidth <= 768 ? true : false, // 移动端允许touch, PC禁止
      effect: window.innerWidth <= 768 ? 'fade' : 'slide', // 移动端开启fade切换效果
      fadeEffect: window.innerWidth <= 768 ? { crossFade: true } : undefined,
      breakpoints: {
        768: {

          slidesPerView: 1,
          centeredSlides: false,
          spaceBetween: 50,
          allowTouchMove: false, // 移动端开
        },
      },
      on: {
        init() {
          setTimeout(() => {
            runSlideLogic(this.slides[this.activeIndex]);
            setSlideTitleAnimated(this, 'right');
            // 激活对应的导航按钮
            navBtns.forEach(b => b.classList.remove('active'));
            if (navBtns[this.activeIndex]) navBtns[this.activeIndex].classList.add('active');
            setUnifiedSlideHeight();
          }, 100);
        },
        slideChangeTransitionStart() {
          resetState();
        },
        slideChangeTransitionEnd() {
          setSlideTitleAnimated(this, lastDirection);
          runSlideLogic(this.slides[this.activeIndex]);
          // 激活对应的导航按钮
          navBtns.forEach(b => b.classList.remove('active'));
          if (navBtns[this.activeIndex]) navBtns[this.activeIndex].classList.add('active');
          setUnifiedSlideHeight();
        },
        touchStart(swiper, event) {
          swiper._touchStartIndex = swiper.activeIndex;
          swiper._touchStartX = event.touches?.[0]?.clientX;
        },
        touchEnd(swiper, event) {
          if (window.innerWidth > 768) return;
          const prevIndex = swiper._touchStartIndex;
          const nowIndex = swiper.activeIndex;
          let direction = 'right';
          if (nowIndex < prevIndex) direction = 'left';
          if (nowIndex > prevIndex) direction = 'right';
          if (nowIndex !== prevIndex) {
            lastDirection = direction;
            setTimeout(() => setSlideTitleAnimated(swiper, direction), 50);
            // 激活对应的导航按钮（在移动端触摸时也同步按钮）
            navBtns.forEach(b => b.classList.remove('active'));
            if (navBtns[nowIndex]) navBtns[nowIndex].classList.add('active');
          }
        },
      },
    });
    window.mySwiper = mySwiper;

    // 按钮状态
    {% comment %} function updateNavBtnStatus() {
      if (!btnPrev || !btnNext) return;
      if (mySwiper.isBeginning || mySwiper.activeIndex === 0) {
        btnPrev.classList.add('disabled');
        btnPrev.style.pointerEvents = 'none';
        btnPrev.style.opacity = '0.5';
      } else {
        btnPrev.classList.remove('disabled');
        btnPrev.style.pointerEvents = '';
        btnPrev.style.opacity = '';
      }
      btnNext.classList.remove('disabled');
      btnNext.style.pointerEvents = '';
      btnNext.style.opacity = '';
    } {% endcomment %}
    const applyTitleAnimOnBtn = (direction) => setSlideTitleAnimated(mySwiper, direction);

    // slide宽度自适应
    const updateMobileSlideWidth = () => {
      const isMobile = window.innerWidth <= 768;
      const slides = document.querySelectorAll('.x-one-production-system-{{ section.id }} .swiper-slide');
      slides.forEach((slide) => {
        slide.style.width = isMobile ? `${window.innerWidth}px` : '1000px';
      });
      if (window.mySwiper && typeof window.mySwiper.update === 'function') {
        window.mySwiper.update();
      }
      {% comment %} setTimeout(updateNavBtnStatus, 100); {% endcomment %}
      setTimeout(setUnifiedSlideHeight, 110);
    };
    window.addEventListener('resize', updateMobileSlideWidth);
    updateMobileSlideWidth();


    const runSlideLogic = (slide) => {
        if (!slide) return;
      
        const type = slide.getAttribute('data-type');
      
        // ==============================
        // 视频逻辑（PC + 移动端都执行）
        // ==============================
        if (type === 'video') {
      
          const video = slide.querySelector('video');
          if (!video) return;
      
          currentVideo = video;
          video.currentTime = 0;
      
          const playPromise = video.play();
      
          if (playPromise !== undefined) {
            playPromise.catch(() => {
              // 某些浏览器策略限制时不报错
            });
          }
      
          // 移动端才自动跳下一张
          {% comment %} if (window.innerWidth <= 768) {
            video.onended = () => {
              if (mySwiper.isEnd) {
                mySwiper.slideTo(0);
              } else {
                mySwiper.slideNext();
              }
            };
          } {% endcomment %}
      
          return;
        }
      
        // ==============================
        // 移动端图片自动轮播
        // ==============================
        {% comment %} if (window.innerWidth <= 768) {
      
          const duration = parseInt(slide.getAttribute('data-duration')) || 3000;
      
          startProgress(duration);
      
          timer = setTimeout(() => {
            if (mySwiper.isEnd) {
              mySwiper.slideTo(0);
            } else {
              mySwiper.slideNext();
            }
          }, duration);
        } {% endcomment %}
      };
      
    // 进度环动画
    const startProgress = (durationMs) => {
      if (!progressCircle) return;
      progressCircle.style.transition = 'none';
      progressCircle.style.strokeDashoffset = circumference;
      progressCircle.getBoundingClientRect();
      progressCircle.style.transition = `stroke-dashoffset ${durationMs}ms linear`;
      progressCircle.style.strokeDashoffset = '0';
    };

    // 状态重置
    const resetState = () => {
      if (timer) clearTimeout(timer);
      if (currentVideo) {
        currentVideo.pause();
        currentVideo.onended = null;
        currentVideo = null;
      }
      if (progressCircle) {
        progressCircle.style.transition = 'none';
        progressCircle.style.strokeDashoffset = circumference;
      }

      const titles = document.querySelectorAll('.x-one-production-system-{{ section.id }} .text-area');
      titles.forEach((t) => {
        t.classList.remove('animated', 'fadeIn');
        t.style.opacity = '0';
        t.style.position = "absolute";
        t.style.zIndex = -1;
        t.style.marginBottom = '0';
      });
    };

    // 按钮切换逻辑（保留）
    // custom-controls-nav 下 nav-btn-new 点击切换对应slide

    navBtns.forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        if (mySwiper.activeIndex === idx) return;
        resetState();
        lastDirection = idx > mySwiper.activeIndex ? 'right' : 'left';
        mySwiper.slideTo(idx);

        // 激活的元素添加active
        navBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        setTimeout(() => {
          applyTitleAnimOnBtn(lastDirection);
        }, 50);
        setTimeout(setUnifiedSlideHeight, 120);
      });
    });
    if (btnPrev) {
      btnPrev.addEventListener('click', () => {
        if (mySwiper.isBeginning || mySwiper.activeIndex === 0) return;
        resetState();
        lastDirection = 'left';
        mySwiper.slidePrev();
        setTimeout(() => {
          applyTitleAnimOnBtn('left');
        }, 50);
        setTimeout(setUnifiedSlideHeight, 120);
      });
    }
    if (btnNext) {
      btnNext.addEventListener('click', () => {
        resetState();
        lastDirection = 'right';
        if (mySwiper.isEnd || mySwiper.activeIndex === mySwiper.slides.length - 1) {
          mySwiper.slideTo(0);
        } else {
          mySwiper.slideNext();
        }
        setTimeout(() => {
          applyTitleAnimOnBtn('right');
        }, 50);
        setTimeout(setUnifiedSlideHeight, 120);
      });
    }

    mySwiper.on('transitionEnd', () => {
      setSlideTitleAnimated(mySwiper, lastDirection);
      {% comment %} updateNavBtnStatus(); {% endcomment %}
      setUnifiedSlideHeight();
    });
    setTimeout(() => {
      setSlideTitleAnimated(mySwiper, 'right');
      {% comment %} updateNavBtnStatus(); {% endcomment %}
      setUnifiedSlideHeight();
    }, 100);

    // 图片、字体变动后高度同步
    const imgs = document.querySelectorAll('.x-one-production-system-{{ section.id }} img');
    imgs.forEach((img) => {
      img.addEventListener('load', setUnifiedSlideHeight);
    });
    if ('fonts' in document) {
      document.fonts.ready.finally(setUnifiedSlideHeight);
    }

    // ----------------
    // PC端 - 利用ScrollTrigger.min.js监听滚轮触发切换
    // ----------------
    if ( window.gsap !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      let hasPlayed = false;
      const container = document.querySelector('.x-one-production-system-{{ section.id }} .main-wrapper');
      const totalSlides = mySwiper.slides.length;
      {% comment %} const scrollDistance = totalSlides * window.innerHeight; {% endcomment %}
       // 每一张slide只需要滚动 600px 就切换
      const perSlideDistance = 600;
      const scrollDistance = perSlideDistance * (totalSlides - 1);

      {% comment %}
        利用 GSAP 的 ScrollTrigger 插件创建滚动触发器，实现页面滚动时幻灯片(slide)切换效果
        - trigger: 以 container 元素为触发对象
        - start: 当container顶部对齐视口顶部时开始
        - end: 滚动距离为所有幻灯片高度总和
        - pin: 滚动时固定(container钉在页面上)
        - scrub: 平滑滚动, 值越大阻尼越大，这里为0.3
        - snap: 自动吸附到每一个slide
          - snapTo: slide数量等分，自动计算每个 slide 的位置
          - duration: 吸附动画持续时间
          - ease: 缓动效果
        - onUpdate: 滚动时执行
          - 根据滚动进度 progress 计算当前 slideIndex
          - 若 slideIndex 发生变化，则
            - 调用 resetState() 重置动画状态
            - 判断左右切换方向
            - 切换到对应 slide (mySwiper.slideTo)
      {% endcomment %}
      // 使用 ScrollTrigger 的 onEnter 只在进入显示区域时，触发一次动效
      ScrollTrigger.create({
        trigger: container,
        start: "top top",
        end: "bottom bottom",
        invalidateOnRefresh: true,

        onEnter: () => {
          runSlideLogic(mySwiper.slides[mySwiper.activeIndex]);
        },
        onEnterBack: () => {
          // 向上滚动再次触发
          runSlideLogic(mySwiper.slides[mySwiper.activeIndex]);
        },
      });
    }

    // 若窗口resize到PC与移动间需reload，否则触发方式有差异
  });
</script>

